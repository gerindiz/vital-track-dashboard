# VitalTrack — Variables de entorno
# Copiá este archivo como .env y completá con tus credenciales de Supabase

# Supabase Project URL
# Encontralo en: https://app.supabase.com → Settings → API → Project URL
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anonymous Key (pública, segura de exponer en el frontend)
# Encontrala en: https://app.supabase.com → Settings → API → anon / public
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
